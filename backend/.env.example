# video downloader Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# CORS - comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-frontend.vercel.app

# yt-dlp path (default: 'yt-dlp' assumes it's in PATH)
YT_DLP_PATH=yt-dlp

# ffmpeg path (optional, default: 'ffmpeg' assumes it's in PATH)
FFMPEG_PATH=ffmpeg

# Timeout for yt-dlp operations in milliseconds
YT_DLP_TIMEOUT=30000

# Max download file size in bytes (default 2GB)
MAX_DOWNLOAD_SIZE=2147483648
